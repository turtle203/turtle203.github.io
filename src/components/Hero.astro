---
---

<section class="hero" id="home">
  <div class="hero-grid-bg"></div>
  <div class="hero-scanline"></div>

  <div class="hero-content">
    <div class="hero-eyebrow">
      <span class="hero-eyebrow-dot"></span>
      <span class="hero-eyebrow-text" id="typewriter"></span>
      <span class="hero-cursor">_</span>
    </div>

    <h1 class="hero-name">
      <span class="hero-name-first">Ibrahim</span>
      <span class="hero-name-last">Gul</span>
    </h1>

    <p class="hero-title">
      Offensive Security Engineer
      <span class="hero-divider">&</span>
      Full-Stack Developer
    </p>

    <p class="hero-bio">
      Breaking systems to make them stronger. Building software with security at its core.
      Red team specialist with enterprise and startup experience across the full stack.
    </p>

    <div class="hero-actions">
      <a href="#projects" class="btn-primary">
        <span class="btn-icon">&gt;</span> View Projects
      </a>
      <a href="#contact" class="btn-secondary">Get in touch</a>
    </div>

    <div class="hero-stats">
      <div class="stat">
        <span class="stat-num">5+</span>
        <span class="stat-label">Years Experience</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat">
        <span class="stat-num">2</span>
        <span class="stat-label">Industry Levels</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat">
        <span class="stat-num">∞</span>
        <span class="stat-label">Attack Vectors</span>
      </div>
    </div>
  </div>

  <div class="hero-visual">
    <div class="hex-container">
      <div class="hex hex-1">
        <div class="hex-inner">
          <span class="hex-icon">&#9760;</span>
          <span class="hex-label">Red Team</span>
        </div>
      </div>
      <div class="hex hex-2">
        <div class="hex-inner">
          <span class="hex-icon">&#128274;</span>
          <span class="hex-label">AppSec</span>
        </div>
      </div>
      <div class="hex hex-3">
        <div class="hex-inner">
          <span class="hex-icon">&#9729;</span>
          <span class="hex-label">Cloud</span>
        </div>
      </div>
      <div class="hex hex-4">
        <div class="hex-inner">
          <span class="hex-icon">&#128187;</span>
          <span class="hex-label">DevOps</span>
        </div>
      </div>
      <div class="hex hex-center">
        <div class="hex-inner hex-inner-center">
          <span class="hex-center-text">IG</span>
        </div>
      </div>
      <div class="orbit-ring ring-1"></div>
      <div class="orbit-ring ring-2"></div>
    </div>
  </div>

  <div class="hero-scroll-hint">
    <span>scroll</span>
    <div class="scroll-line"></div>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    padding: 7rem 2.5rem 4rem;
    max-width: 1200px;
    margin: 0 auto;
    position: relative;
    gap: 4rem;
  }

  .hero-grid-bg {
    position: fixed;
    inset: 0;
    background-image:
      linear-gradient(rgba(30, 111, 255, 0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(30, 111, 255, 0.04) 1px, transparent 1px);
    background-size: 60px 60px;
    pointer-events: none;
    z-index: 0;
  }

  .hero-scanline {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, rgba(30, 111, 255, 0.15), transparent);
    animation: scanline 8s linear infinite;
    pointer-events: none;
    z-index: 1;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    animation: fadeUp 0.8s ease both;
  }

  .hero-eyebrow {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--blue-bright);
    letter-spacing: 0.12em;
    margin-bottom: 1.5rem;
  }

  .hero-eyebrow-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--blue-core);
    box-shadow: 0 0 8px var(--blue-core);
    animation: float 3s ease-in-out infinite;
    flex-shrink: 0;
  }

  .hero-cursor {
    animation: blink 1s step-end infinite;
    color: var(--blue-core);
  }

  .hero-name {
    font-family: var(--font-display);
    font-size: clamp(3.5rem, 7vw, 6rem);
    font-weight: 800;
    line-height: 0.9;
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
  }

  .hero-name-first {
    display: block;
    color: var(--text-primary);
    animation: fadeUp 0.8s 0.1s ease both;
    opacity: 0;
  }

  .hero-name-last {
    display: block;
    color: transparent;
    -webkit-text-stroke: 1px var(--blue-core);
    animation: fadeUp 0.8s 0.2s ease both;
    opacity: 0;
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 500;
    color: var(--text-secondary);
    margin-bottom: 1.5rem;
    animation: fadeUp 0.8s 0.3s ease both;
    opacity: 0;
  }

  .hero-divider {
    color: var(--blue-core);
    margin: 0 0.5rem;
  }

  .hero-bio {
    font-size: 0.95rem;
    color: var(--text-secondary);
    max-width: 460px;
    margin-bottom: 2.5rem;
    line-height: 1.8;
    animation: fadeUp 0.8s 0.4s ease both;
    opacity: 0;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    margin-bottom: 3rem;
    animation: fadeUp 0.8s 0.5s ease both;
    opacity: 0;
  }

  .btn-primary {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    letter-spacing: 0.08em;
    color: var(--bg-primary);
    background: var(--blue-core);
    padding: 0.75rem 1.75rem;
    text-decoration: none;
    border-radius: 2px;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    transition: background 0.2s, box-shadow 0.2s, transform 0.1s;
  }

  .btn-primary:hover {
    background: var(--blue-bright);
    box-shadow: 0 0 20px rgba(30, 111, 255, 0.4);
    transform: translateY(-1px);
  }

  .btn-icon {
    font-weight: bold;
  }

  .btn-secondary {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    letter-spacing: 0.08em;
    color: var(--text-secondary);
    border: 1px solid var(--border-mid);
    padding: 0.75rem 1.75rem;
    text-decoration: none;
    border-radius: 2px;
    transition: border-color 0.2s, color 0.2s, box-shadow 0.2s;
  }

  .btn-secondary:hover {
    border-color: var(--blue-core);
    color: var(--blue-bright);
    box-shadow: inset 0 0 20px rgba(30, 111, 255, 0.05);
  }

  .hero-stats {
    display: flex;
    align-items: center;
    gap: 2rem;
    animation: fadeUp 0.8s 0.6s ease both;
    opacity: 0;
  }

  .stat {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .stat-num {
    font-family: var(--font-display);
    font-size: 1.8rem;
    font-weight: 700;
    color: var(--blue-bright);
    line-height: 1;
  }

  .stat-label {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    color: var(--text-muted);
    text-transform: uppercase;
  }

  .stat-divider {
    width: 1px;
    height: 2rem;
    background: var(--border-dim);
  }

  /* Hero Visual */
  .hero-visual {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: center;
    animation: fadeIn 1.2s 0.4s ease both;
    opacity: 0;
  }

  .hex-container {
    position: relative;
    width: 360px;
    height: 360px;
  }

  .hex {
    position: absolute;
    width: 90px;
    height: 90px;
  }

  .hex-inner {
    width: 100%;
    height: 100%;
    background: var(--bg-card);
    border: 1px solid var(--border-mid);
    border-radius: 8px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    transition: border-color 0.3s, box-shadow 0.3s;
    cursor: default;
  }

  .hex-inner:hover {
    border-color: var(--blue-core);
    box-shadow: 0 0 20px rgba(30, 111, 255, 0.2);
  }

  .hex-icon {
    font-size: 1.5rem;
    line-height: 1;
  }

  .hex-label {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: var(--text-muted);
    letter-spacing: 0.1em;
  }

  .hex-1 { top: 20px; left: 50%; transform: translateX(-50%); animation: float 4s 0s ease-in-out infinite; }
  .hex-2 { top: 50%; right: 20px; transform: translateY(-50%); animation: float 4s 0.5s ease-in-out infinite; }
  .hex-3 { bottom: 20px; left: 50%; transform: translateX(-50%); animation: float 4s 1s ease-in-out infinite; }
  .hex-4 { top: 50%; left: 20px; transform: translateY(-50%); animation: float 4s 1.5s ease-in-out infinite; }

  .hex-center {
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 110px;
    height: 110px;
  }

  .hex-inner-center {
    background: linear-gradient(135deg, var(--blue-mid), var(--bg-card));
    border-color: var(--blue-core);
    box-shadow: 0 0 40px rgba(30, 111, 255, 0.2);
  }

  .hex-center-text {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 800;
    color: var(--blue-glow);
    letter-spacing: 0.05em;
  }

  .orbit-ring {
    position: absolute;
    top: 50%;
    left: 50%;
    border-radius: 50%;
    border: 1px solid var(--border-dim);
    transform: translate(-50%, -50%);
    pointer-events: none;
  }

  .ring-1 {
    width: 200px;
    height: 200px;
    animation: pulse-border 4s ease-in-out infinite;
  }

  .ring-2 {
    width: 300px;
    height: 300px;
    animation: pulse-border 4s 2s ease-in-out infinite;
  }

  .hero-scroll-hint {
    position: absolute;
    bottom: 2rem;
    left: 2.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    z-index: 2;
  }

  .hero-scroll-hint span {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    color: var(--text-muted);
    text-transform: uppercase;
    writing-mode: vertical-rl;
  }

  .scroll-line {
    width: 1px;
    height: 60px;
    background: linear-gradient(to bottom, var(--text-muted), transparent);
    animation: fadeIn 2s ease infinite alternate;
  }

  @media (max-width: 900px) {
    .hero {
      grid-template-columns: 1fr;
      padding-top: 6rem;
      gap: 3rem;
      text-align: center;
    }

    .hero-bio {
      max-width: 100%;
    }

    .hero-actions {
      justify-content: center;
    }

    .hero-stats {
      justify-content: center;
    }

    .hero-scroll-hint {
      display: none;
    }

    .hero-visual {
      order: -1;
    }

    .hex-container {
      width: 280px;
      height: 280px;
    }

    .hex { width: 70px; height: 70px; }
    .hex-center { width: 90px; height: 90px; }

    .hero-eyebrow {
      justify-content: center;
    }
  }
</style>

<script>
  const phrases = [
    'whoami: security_engineer',
    'nmap -sV --open target.io',
    'git commit -m "fix: CVE-2024-####"',
    'sudo ./exploit.py --target all',
    'ssh ibrahim@ibrahimgul.dev',
  ];

  let phraseIdx = 0;
  let charIdx = 0;
  let deleting = false;
  const el = document.getElementById('typewriter');

  function type() {
    const current = phrases[phraseIdx];
    if (!deleting) {
      if (el) el.textContent = current.slice(0, charIdx + 1);
      charIdx++;
      if (charIdx === current.length) {
        deleting = true;
        setTimeout(type, 2000);
        return;
      }
    } else {
      if (el) el.textContent = current.slice(0, charIdx - 1);
      charIdx--;
      if (charIdx === 0) {
        deleting = false;
        phraseIdx = (phraseIdx + 1) % phrases.length;
      }
    }
    setTimeout(type, deleting ? 40 : 80);
  }

  type();
</script>
