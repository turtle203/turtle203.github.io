---
const experiences = [
  {
    role: "Cyber Security Specialist & Lead of IT Support",
    company: "Worth AI",
    type: "Security + Operations",
    period: "2024 – Current",
    description: "Lead cybersecurity and IT support operations with focus on SOC2 readiness, endpoint security, and practical risk reduction.",
    impact: "Improved compliance posture by 25%, reduced provisioning time by 80%, and cut downtime by 25%.",
    highlights: [
      "Investigated and resolved 120+ security incidents with a 100% resolution rate",
      "Conducted vulnerability scans and penetration tests and mitigated 15+ critical issues",
      "Configured and secured 70+ macOS endpoints with zero asset loss over 12 months",
      "Managed 20+ technical projects across system deployments, endpoint protection, and remediation",
      "Provided SME support for Office 365, Google Workspace, AWS, Jira, Datadog, and Slack",
    ],
  },
  {
    role: "Senior Enterprise Help Desk Technician Tier 2",
    company: "Apex Systems (Contract for Boeing)",
    type: "Enterprise",
    period: "2021 – 2024",
    description: "Delivered enterprise support and escalation handling for endpoint, identity, and engineering systems in a high-volume environment.",
    impact: "Resolved 200+ high-priority tickets weekly and improved vulnerability remediation turnaround by 40%.",
    highlights: [
      "Resolved 200+ high-priority support tickets weekly with consistent 100% resolution accuracy",
      "Delivered advanced support for Microsoft Office, Active Directory, and enterprise engineering apps",
      "Implemented PowerShell automation to reduce account provisioning time and misconfigurations",
      "Configured and managed 300+ accounts per month across Webex, Palo Alto, and mobile integrations",
      "Collaborated with server teams to accelerate patching and security remediation",
    ],
  },
  {
    role: "Customer Service Team Lead",
    company: "Publix Super Markets",
    type: "Leadership",
    period: "Pre-2021",
    description: "Led frontline operations and escalations with strong focus on system accuracy, queue flow, and team performance.",
    impact: "Supervised 80+ associates and maintained 98%+ customer satisfaction across 250+ weekly transactions.",
    highlights: [
      "Improved cash handling and transaction accuracy through process enforcement",
      "Managed queue flow and order systems including Western Union and MoneyGram",
      "Handled high-volume escalations while maintaining service quality and speed",
      "Coached associates on communication, execution, and operational consistency",
    ],
  },
];
---

<section class="experience" id="experience">
  <div class="container">
    <div class="section-label">03. Track Record</div>
    <h2 class="section-title">Experience</h2>

    <div class="timeline">
      {experiences.map((exp, i) => (
        <div class="timeline-item" style={`animation-delay: ${i * 0.15}s`}>
          <div class="timeline-marker">
            <div class="timeline-dot"></div>
            <div class="timeline-line"></div>
          </div>
          <div class="timeline-content">
            <div class="timeline-header">
              <div class="timeline-title-group">
                <h3 class="timeline-role">{exp.role}</h3>
                <span class="timeline-company">{exp.company}</span>
              </div>
              <div class="timeline-meta">
                <span class="timeline-badge">{exp.type}</span>
                <span class="timeline-period">{exp.period}</span>
              </div>
            </div>
            <p class="timeline-desc">{exp.description}</p>
            <p class="timeline-impact">{exp.impact}</p>
            <ul class="timeline-highlights">
              {exp.highlights.map(h => (
                <li class="timeline-highlight">
                  <span class="highlight-arrow">&rsaquo;</span>
                  {h}
                </li>
              ))}
            </ul>
          </div>
        </div>
      ))}
    </div>

    <div class="certs-row">
      <div class="section-label" style="margin-bottom: 1.5rem;">Certifications & Training</div>
      <div class="certs-grid">
        <div class="cert-item">
          <span class="cert-dot"></span>
          <span>B.A.S. in Cybersecurity, St. Petersburg College (2021-2025)</span>
        </div>
        <div class="cert-item">
          <span class="cert-dot"></span>
          <span>Certificate of Cybersecurity (CAE2Y - NSA/DHS)</span>
        </div>
        <div class="cert-item">
          <span class="cert-dot"></span>
          <span>CompTIA A+ and CompTIA Security+</span>
        </div>
        <div class="cert-item">
          <span class="cert-dot"></span>
          <span>Active Civilian Level Security Clearance (2020-2024)</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .experience {
    padding: 6rem 2.5rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 2.8rem);
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 3rem;
    letter-spacing: -0.02em;
  }

  .timeline {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin-bottom: 4rem;
  }

  .timeline-item {
    display: grid;
    grid-template-columns: 40px 1fr;
    gap: 1.5rem;
    opacity: 0;
    animation: fadeUp 0.6s ease forwards;
  }

  .timeline-marker {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-top: 0.5rem;
  }

  .timeline-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--blue-core);
    box-shadow: 0 0 10px rgba(30, 111, 255, 0.5);
    flex-shrink: 0;
    z-index: 1;
  }

  .timeline-line {
    width: 1px;
    flex: 1;
    background: linear-gradient(to bottom, var(--border-mid), var(--border-dim));
    margin-top: 4px;
  }

  .timeline-item:last-child .timeline-line {
    display: none;
  }

  .timeline-content {
    background: var(--bg-card);
    border: 1px solid var(--border-dim);
    border-radius: 4px;
    padding: 1.75rem;
    margin-bottom: 1.5rem;
    transition: border-color 0.3s;
  }

  .timeline-content:hover {
    border-color: var(--border-mid);
  }

  .timeline-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 1rem;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .timeline-role {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 0.2rem;
  }

  .timeline-company {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--blue-bright);
    letter-spacing: 0.05em;
  }

  .timeline-meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.4rem;
  }

  .timeline-badge {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--blue-core);
    border: 1px solid var(--border-mid);
    padding: 0.2rem 0.6rem;
    border-radius: 2px;
  }

  .timeline-period {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-muted);
    letter-spacing: 0.05em;
  }

  .timeline-desc {
    font-size: 0.9rem;
    color: var(--text-secondary);
    margin-bottom: 0.65rem;
    line-height: 1.7;
  }

  .timeline-impact {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--blue-bright);
    letter-spacing: 0.04em;
    margin-bottom: 1rem;
    line-height: 1.6;
  }

  .timeline-highlights {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .timeline-highlight {
    font-size: 0.85rem;
    color: var(--text-secondary);
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
  }

  .highlight-arrow {
    color: var(--blue-core);
    font-size: 1.1rem;
    flex-shrink: 0;
  }

  .certs-row {
    border-top: 1px solid var(--border-dim);
    padding-top: 3rem;
  }

  .certs-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1rem;
  }

  .cert-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.88rem;
    color: var(--text-secondary);
    background: var(--bg-card);
    border: 1px solid var(--border-dim);
    border-radius: 4px;
    padding: 0.9rem 1.25rem;
    transition: border-color 0.2s;
  }

  .cert-item:hover {
    border-color: var(--border-mid);
  }

  .cert-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--blue-core);
    flex-shrink: 0;
  }
</style>
