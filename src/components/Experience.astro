---
const experiences = [
  {
    role: "Cybersecurity Operations",
    company: "Cross-Industry Environments",
    type: "Security + Compliance",
    period: "Recent Focus",
    description: "Hands-on security operations across endpoint protection, incident triage, vulnerability management, and policy-driven hardening.",
    impact: "Outcome-focused work that improved compliance posture, increased reliability, and reduced operational friction.",
    projects: ["Security Program Delivery", "Monitoring and Hardening"],
    highlights: [
      "Handled 120+ incident investigations and escalations with strong resolution consistency",
      "Mitigated critical findings through recurring vulnerability scans and remediation workflows",
      "Hardened and managed 70+ endpoints with improved asset control and security baselines",
      "Supported security tooling and operations across cloud and collaboration platforms",
    ],
  },
  {
    role: "IT Systems & Endpoint Engineering",
    company: "Enterprise and Growth Teams",
    type: "Infrastructure",
    period: "Core Experience",
    description: "Built repeatable endpoint provisioning and support workflows with emphasis on automation, identity hygiene, and system uptime.",
    impact: "Reduced provisioning delays and improved remediation speed through scripting and process refinement.",
    projects: ["Endpoint Automation", "Infrastructure Reliability"],
    highlights: [
      "Resolved high-priority support issues across endpoint, identity, and collaboration systems",
      "Automated account and endpoint tasks with PowerShell and Bash to reduce manual drift",
      "Managed large-scale account lifecycle operations with better consistency and turnaround",
      "Partnered with infrastructure teams to accelerate patching and remediation cycles",
    ],
  },
  {
    role: "Applied Security Projects",
    company: "Independent + Collaborative Builds",
    type: "Product + Research",
    period: "Ongoing",
    description: "Translate operational security knowledge into practical tools and full-stack projects that prioritize secure design and measurable outcomes.",
    impact: "Projects are scoped around real-world workflows: secure access, observability, and defensive automation.",
    projects: ["Secure Product Engineering", "Defensive Research"],
    highlights: [
      "Built full-stack SaaS flows using Django and React with role-based access controls",
      "Designed Python-based reconnaissance and assessment utilities for security analysis",
      "Implemented CI/CD, logging, and monitoring patterns to support safer iteration",
      "Developed IDS and network defense prototypes as part of cybersecurity coursework",
    ],
  },
];
---

<section class="experience" id="experience">
  <div class="container">
    <div class="section-label">03. Operational Highlights</div>
    <h2 class="section-title">Operational Highlights</h2>

    <div class="timeline">
      {experiences.map((exp, i) => (
        <div class="timeline-item" style={`animation-delay: ${i * 0.15}s`}>
          <div class="timeline-marker">
            <div class="timeline-dot"></div>
            <div class="timeline-line"></div>
          </div>
          <div class="timeline-content">
            <div class="timeline-header">
              <div class="timeline-title-group">
                <h3 class="timeline-role">{exp.role}</h3>
                <span class="timeline-company">{exp.company}</span>
              </div>
              <div class="timeline-meta">
                <span class="timeline-badge">{exp.type}</span>
                <span class="timeline-period">{exp.period}</span>
              </div>
            </div>
            <p class="timeline-desc">{exp.description}</p>
            <p class="timeline-impact">{exp.impact}</p>
            <div class="timeline-projects">
              {exp.projects.map(project => (
                <a href="#projects" class="timeline-project-chip">{project}</a>
              ))}
            </div>
            <ul class="timeline-highlights">
              {exp.highlights.map(h => (
                <li class="timeline-highlight">
                  <span class="highlight-arrow">&rsaquo;</span>
                  {h}
                </li>
              ))}
            </ul>
          </div>
        </div>
      ))}
    </div>

    <div class="certs-row">
      <div class="section-label" style="margin-bottom: 1.5rem;">Certifications & Training</div>
      <div class="certs-grid">
        <div class="cert-item">
          <span class="cert-dot"></span>
          <span>Bachelor of Applied Science in Cybersecurity</span>
        </div>
        <div class="cert-item">
          <span class="cert-dot"></span>
          <span>Certificate of Cybersecurity</span>
        </div>
        <div class="cert-item">
          <span class="cert-dot"></span>
          <span>CompTIA A+</span>
        </div>
        <div class="cert-item">
          <span class="cert-dot"></span>
          <span>CompTIA Security+</span>
        </div>
        <div class="cert-item">
          <span class="cert-dot"></span>
          <span>AWS Security Certifications</span>
        </div>
        <div class="cert-item">
          <span class="cert-dot"></span>
          <span>Cisco Networking Certifications</span>
        </div>
        <div class="cert-item">
          <span class="cert-dot"></span>
          <span>Cisco Network Security Certifications</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .experience {
    padding: 6rem 2.5rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 2.8rem);
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 3rem;
    letter-spacing: -0.02em;
  }

  .timeline {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin-bottom: 4rem;
  }

  .timeline-item {
    display: grid;
    grid-template-columns: 40px 1fr;
    gap: 1.5rem;
    opacity: 0;
    animation: fadeUp 0.6s ease forwards;
  }

  .timeline-marker {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-top: 0.5rem;
  }

  .timeline-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--blue-core);
    box-shadow: 0 0 10px rgba(30, 111, 255, 0.5);
    flex-shrink: 0;
    z-index: 1;
  }

  .timeline-line {
    width: 1px;
    flex: 1;
    background: linear-gradient(to bottom, var(--border-mid), var(--border-dim));
    margin-top: 4px;
  }

  .timeline-item:last-child .timeline-line {
    display: none;
  }

  .timeline-content {
    background: var(--bg-card);
    border: 1px solid var(--border-dim);
    border-radius: 4px;
    padding: 1.75rem;
    margin-bottom: 1.5rem;
    transition: border-color 0.3s;
  }

  .timeline-content:hover {
    border-color: var(--border-mid);
  }

  .timeline-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 1rem;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .timeline-role {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 0.2rem;
  }

  .timeline-company {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--blue-bright);
    letter-spacing: 0.05em;
  }

  .timeline-meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.4rem;
  }

  .timeline-badge {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--blue-core);
    border: 1px solid var(--border-mid);
    padding: 0.2rem 0.6rem;
    border-radius: 2px;
  }

  .timeline-period {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-muted);
    letter-spacing: 0.05em;
  }

  .timeline-desc {
    font-size: 0.9rem;
    color: var(--text-secondary);
    margin-bottom: 0.65rem;
    line-height: 1.7;
  }

  .timeline-impact {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--blue-bright);
    letter-spacing: 0.04em;
    margin-bottom: 1rem;
    line-height: 1.6;
  }

  .timeline-projects {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .timeline-project-chip {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.06em;
    color: var(--blue-bright);
    text-decoration: none;
    background: rgba(30, 111, 255, 0.06);
    border: 1px solid rgba(30, 111, 255, 0.15);
    border-radius: 2px;
    padding: 0.2rem 0.55rem;
    transition: border-color 0.2s, background 0.2s;
  }

  .timeline-project-chip:hover {
    border-color: var(--blue-core);
    background: rgba(30, 111, 255, 0.12);
  }

  .timeline-highlights {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .timeline-highlight {
    font-size: 0.85rem;
    color: var(--text-secondary);
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
  }

  .highlight-arrow {
    color: var(--blue-core);
    font-size: 1.1rem;
    flex-shrink: 0;
  }

  .certs-row {
    border-top: 1px solid var(--border-dim);
    padding-top: 3rem;
  }

  .certs-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1rem;
  }

  .cert-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.88rem;
    color: var(--text-secondary);
    background: var(--bg-card);
    border: 1px solid var(--border-dim);
    border-radius: 4px;
    padding: 0.9rem 1.25rem;
    transition: border-color 0.2s;
  }

  .cert-item:hover {
    border-color: var(--border-mid);
  }

  .cert-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--blue-core);
    flex-shrink: 0;
  }
</style>
