---

<nav class="nav">
  <div class="nav-logo">
    <span class="nav-logo-bracket">[</span>IG<span class="nav-logo-bracket">]</span>
  </div>
  <ul class="nav-links">
    <li><a href="#about">about</a></li>
    <li><a href="#skills">skills</a></li>
    <li><a href="#experience">highlights</a></li>
    <li><a href="#projects">initiatives</a></li>
    <li><a href="#contact" class="nav-cta">contact</a></li>
  </ul>
  <button class="nav-hamburger" aria-label="Menu">
    <span></span><span></span><span></span>
  </button>
</nav>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.25rem 2.5rem;
    background: rgba(8, 13, 19, 0.8);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border-dim);
    transition: border-color 0.3s;
  }

  .nav:hover {
    border-bottom-color: var(--border-mid);
  }

  .nav-logo {
    font-family: var(--font-mono);
    font-size: 1.1rem;
    color: var(--text-primary);
    letter-spacing: 0.05em;
  }

  .nav-logo-bracket {
    color: var(--blue-core);
  }

  .nav-links {
    display: flex;
    list-style: none;
    gap: 2.5rem;
    align-items: center;
  }

  .nav-links a {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.1em;
    color: var(--text-secondary);
    text-decoration: none;
    text-transform: lowercase;
    transition: color 0.2s;
    position: relative;
  }

  .nav-links a::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 1px;
    background: var(--blue-core);
    transition: width 0.2s;
  }

  .nav-links a:hover {
    color: var(--text-primary);
  }

  .nav-links a:hover::after {
    width: 100%;
  }

  .nav-cta {
    color: var(--blue-core) !important;
    border: 1px solid var(--border-mid);
    padding: 0.4rem 1rem;
    border-radius: 2px;
    transition: background 0.2s, color 0.2s !important;
  }

  .nav-cta:hover {
    background: rgba(30, 111, 255, 0.1) !important;
    color: var(--blue-bright) !important;
  }

  .nav-cta::after {
    display: none !important;
  }

  .nav-hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
  }

  .nav-hamburger span {
    display: block;
    width: 22px;
    height: 1px;
    background: var(--text-secondary);
    transition: 0.2s;
  }

  @media (max-width: 768px) {
    .nav {
      padding: 1rem 1.5rem;
    }

    .nav-links {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      flex-direction: column;
      padding: 1.5rem;
      background: var(--bg-secondary);
      border-bottom: 1px solid var(--border-dim);
      gap: 1.5rem;
    }

    .nav-links.open {
      display: flex;
    }

    .nav-hamburger {
      display: flex;
    }
  }
</style>

<script>
  const hamburger = document.querySelector('.nav-hamburger');
  const navLinks = document.querySelector('.nav-links');

  hamburger?.addEventListener('click', () => {
    navLinks?.classList.toggle('open');
  });

  document.querySelectorAll('.nav-links a').forEach(link => {
    link.addEventListener('click', () => {
      navLinks?.classList.remove('open');
    });
  });
</script>
