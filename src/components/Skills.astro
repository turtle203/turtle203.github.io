---
const skillGroups = [
  {
    label: "Cybersecurity Operations",
    icon: "⚔",
    skills: [
      { name: "Incident Response & Triage", level: 93 },
      { name: "SOC2 Type 2 Compliance", level: 90 },
      { name: "Vulnerability Management", level: 91 },
      { name: "Endpoint Detection & Response", level: 92 },
    ],
  },
  {
    label: "Programming & Scripting",
    icon: "⌨",
    skills: [
      { name: "Python Automation", level: 91 },
      { name: "Bash Hardening Scripts", level: 89 },
      { name: "PowerShell Automation", level: 90 },
      { name: "Security Data Parsing", level: 86 },
    ],
  },
  {
    label: "Cloud & Infrastructure",
    icon: "🖧",
    skills: [
      { name: "AWS / Azure Security", level: 88 },
      { name: "Server Hardening", level: 90 },
      { name: "Active Directory & Exchange", level: 89 },
      { name: "Endpoint Provisioning", level: 94 },
    ],
  },
  {
    label: "IT Operations & Collaboration",
    icon: "🔐",
    skills: [
      { name: "Office 365 / Google Workspace", level: 92 },
      { name: "Jira / ServiceNow Workflows", level: 90 },
      { name: "Datadog Monitoring", level: 87 },
      { name: "Technical Documentation", level: 88 },
    ],
  },
];

const tags = [
  "Wireshark", "Nessus", "Nmap", "Metasploit", "Cloudflare WAF",
  "Office 365", "Google Workspace", "ServiceNow", "Jira", "Confluence",
  "Datadog", "Slack", "AWS IAM", "EC2", "S3",
  "Azure", "Active Directory", "Exchange", "Linux", "macOS", "Windows",
  "PowerShell", "Bash", "Python", "Endpoint Hardening", "SOC2",
];
---

<section class="skills" id="skills">
  <div class="container">
    <div class="section-label">02. Capabilities</div>
    <h2 class="section-title">Skills & Expertise</h2>

    <div class="skills-grid">
      {skillGroups.map((group, i) => (
        <div class="skill-card" style={`animation-delay: ${i * 0.1}s`}>
          <div class="skill-card-header">
            <span class="skill-icon">{group.icon}</span>
            <h3 class="skill-group-label">{group.label}</h3>
          </div>
          <div class="skill-list">
            {group.skills.map(skill => (
              <div class="skill-item">
                <div class="skill-meta">
                  <span class="skill-name">{skill.name}</span>
                  <span class="skill-pct">{skill.level}%</span>
                </div>
                <div class="skill-bar">
                  <div class="skill-bar-fill" style={`--target: ${skill.level}%`}></div>
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>

    <div class="tags-section">
      <div class="section-label" style="margin-bottom: 1.5rem;">Tools & Technologies</div>
      <div class="tags">
        {tags.map(tag => (
          <span class="tag">{tag}</span>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .skills {
    padding: 6rem 2.5rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .container {
    width: 100%;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 2.8rem);
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 3rem;
    letter-spacing: -0.02em;
  }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
    margin-bottom: 4rem;
  }

  .skill-card {
    background: var(--bg-card);
    border: 1px solid var(--border-dim);
    border-radius: 4px;
    padding: 1.75rem;
    transition: border-color 0.3s, box-shadow 0.3s;
    opacity: 0;
    animation: fadeUp 0.6s ease forwards;
  }

  .skill-card:hover {
    border-color: var(--border-mid);
    box-shadow: 0 0 30px rgba(30, 111, 255, 0.08);
  }

  .skill-card-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border-dim);
  }

  .skill-icon {
    font-size: 1.2rem;
  }

  .skill-group-label {
    font-family: var(--font-display);
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text-primary);
    letter-spacing: 0.02em;
  }

  .skill-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .skill-item {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .skill-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .skill-name {
    font-size: 0.82rem;
    color: var(--text-secondary);
    font-weight: 400;
  }

  .skill-pct {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--blue-core);
    letter-spacing: 0.05em;
  }

  .skill-bar {
    height: 2px;
    background: var(--border-dim);
    border-radius: 1px;
    overflow: hidden;
  }

  .skill-bar-fill {
    height: 100%;
    width: 0;
    background: linear-gradient(90deg, var(--blue-core), var(--blue-glow));
    border-radius: 1px;
    transition: width 1.2s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .skill-bar-fill.animated {
    width: var(--target);
  }

  .tags-section {
    border-top: 1px solid var(--border-dim);
    padding-top: 3rem;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }

  .tag {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    color: var(--text-secondary);
    border: 1px solid var(--border-dim);
    padding: 0.35rem 0.8rem;
    border-radius: 2px;
    transition: border-color 0.2s, color 0.2s, background 0.2s;
    cursor: default;
  }

  .tag:hover {
    border-color: var(--blue-core);
    color: var(--blue-bright);
    background: rgba(30, 111, 255, 0.05);
  }
</style>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.querySelectorAll('.skill-bar-fill').forEach(bar => {
          bar.classList.add('animated');
        });
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.2 });

  document.querySelectorAll('.skill-card').forEach(card => observer.observe(card));
</script>
