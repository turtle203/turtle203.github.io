---
const projects = [
  {
    num: "01",
    title: "Spark (AlfaCorp)",
    description: "Co-founded and engineered a full-stack SaaS platform using Django and React for secure project workflows, emphasizing access control, reliability, and scalable architecture.",
    tags: ["Django", "React", "RBAC", "JWT", "SaaS"],
    status: "Active",
    link: "https://github.com/AlfaCorpTech/",
  },
  {
    num: "02",
    title: "Network Scanner Security Tool",
    description: "Built an extensible Python security tool for domain reconnaissance, port scanning, and vulnerability assessment with modular components for TLS and HTTP analysis.",
    tags: ["Python", "Nmap", "TLS Analysis", "Recon", "Automation"],
    status: "Active",
    link: "https://github.com/turtle203",
  },
  {
    num: "03",
    title: "SOC2 Readiness Automation",
    description: "Created security and endpoint automation workflows that standardized hardening, evidence collection, and policy-driven checks to support SOC2 Type 2 readiness.",
    tags: ["SOC2", "Bash", "PowerShell", "Compliance", "Endpoints"],
    status: "Building",
    link: "https://github.com/turtle203",
  },
  {
    num: "04",
    title: "Cloudflare + Monitoring Hardening",
    description: "Implemented WAF and monitoring baselines with Cloudflare and log-focused workflows to improve visibility and identify early indicators of operational or security drift.",
    tags: ["Cloudflare", "Datadog", "WAF", "Monitoring"],
    status: "Complete",
    link: "https://github.com/turtle203",
  },
  {
    num: "05",
    title: "Endpoint Provisioning Workflow",
    description: "Automated device provisioning and configuration for macOS endpoints with scriptable setup, security controls, and consistent baseline policy application.",
    tags: ["macOS", "Deployment", "Endpoint Security", "Automation"],
    status: "Complete",
    link: "https://github.com/turtle203",
  },
  {
    num: "06",
    title: "Cybersecurity Capstone + IDS Prototype",
    description: "Built a custom IDS prototype with open-source tools and completed a breach simulation/remediation capstone focused on practical network defense outcomes.",
    tags: ["IDS", "Network Defense", "Capstone", "Open Source"],
    status: "Ongoing",
    link: "https://github.com/turtle203",
  },
];

const statusColor: Record<string, string> = {
  "Active": "var(--blue-core)",
  "Building": "#f59e0b",
  "Complete": "#10b981",
  "Ongoing": "#8b5cf6",
};
---

<section class="projects" id="projects">
  <div class="container">
    <div class="section-label">04. Work</div>
    <h2 class="section-title">Projects</h2>

    <div class="projects-grid">
      {projects.map((project, i) => (
        <a href={project.link} class="project-card" style={`animation-delay: ${i * 0.08}s`}>
          <div class="project-top">
            <span class="project-num">{project.num}</span>
            <span class="project-status" style={`color: ${statusColor[project.status]}; border-color: ${statusColor[project.status]}40`}>
              <span class="status-dot" style={`background: ${statusColor[project.status]}`}></span>
              {project.status}
            </span>
          </div>
          <h3 class="project-title">{project.title}</h3>
          <p class="project-desc">{project.description}</p>
          <div class="project-tags">
            {project.tags.map(tag => (
              <span class="project-tag">{tag}</span>
            ))}
          </div>
          <div class="project-arrow">→</div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .projects {
    padding: 6rem 2.5rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 2.8rem);
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 3rem;
    letter-spacing: -0.02em;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 1.25rem;
  }

  .project-card {
    background: var(--bg-card);
    border: 1px solid var(--border-dim);
    border-radius: 4px;
    padding: 1.75rem;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    position: relative;
    overflow: hidden;
    transition: border-color 0.3s, transform 0.2s, box-shadow 0.3s;
    opacity: 0;
    animation: fadeUp 0.6s ease forwards;
  }

  .project-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--blue-core), transparent);
    opacity: 0;
    transition: opacity 0.3s;
  }

  .project-card:hover {
    border-color: var(--border-mid);
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(30, 111, 255, 0.1);
  }

  .project-card:hover::before {
    opacity: 1;
  }

  .project-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .project-num {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--text-muted);
    letter-spacing: 0.1em;
  }

  .project-status {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    border: 1px solid;
    padding: 0.2rem 0.6rem;
    border-radius: 2px;
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .status-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
  }

  .project-title {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--text-primary);
  }

  .project-desc {
    font-size: 0.85rem;
    color: var(--text-secondary);
    line-height: 1.7;
    flex: 1;
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 0.25rem;
  }

  .project-tag {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.06em;
    color: var(--blue-bright);
    background: rgba(30, 111, 255, 0.06);
    border: 1px solid rgba(30, 111, 255, 0.15);
    padding: 0.2rem 0.55rem;
    border-radius: 2px;
  }

  .project-arrow {
    font-size: 1.1rem;
    color: var(--text-muted);
    align-self: flex-end;
    transition: color 0.2s, transform 0.2s;
  }

  .project-card:hover .project-arrow {
    color: var(--blue-bright);
    transform: translateX(4px);
  }
</style>
